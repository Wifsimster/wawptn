# ============================================
# WAWPTN - Environment Variables Configuration
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_USER=wawptn
DB_PASSWORD=wawptn_secret
DB_NAME=wawptn
DATABASE_URL=postgresql://wawptn:wawptn_secret@localhost:5432/wawptn

# ============================================
# BACKEND CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ============================================
# AUTHENTICATION (REQUIRED IN PRODUCTION)
# ============================================
# Generate secure secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-change-in-production-min-32-chars
API_URL=http://localhost:3000

# ============================================
# STEAM INTEGRATION (REQUIRED)
# ============================================
# Get your Steam Web API key from https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-web-api-key

# ============================================
# BATTLE.NET INTEGRATION (OPTIONAL)
# ============================================
# BATTLENET_CLIENT_ID=
# BATTLENET_CLIENT_SECRET=

# ============================================
# EPIC GAMES INTEGRATION (OPTIONAL)
# ============================================
# EPIC_CLIENT_ID=
# EPIC_CLIENT_SECRET=
# EPIC_REDIRECT_URI=

# ============================================
# GOG GALAXY INTEGRATION (OPTIONAL)
# ============================================
# GOG_CLIENT_ID=
# GOG_CLIENT_SECRET=
# GOG_REDIRECT_URI=

# ============================================
# DISCORD BOT (OPTIONAL)
# ============================================
# Shared secret between backend and Discord bot
# DISCORD_BOT_API_SECRET=
# Discord bot credentials (for packages/discord)
# DISCORD_BOT_TOKEN=
# DISCORD_APPLICATION_ID=
# BACKEND_URL=http://localhost:3000

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=http://localhost:3000
