# ============================================
# WAWPTN - Environment Variables Configuration
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_USER=wawptn
DB_PASSWORD=wawptn_secret
DB_NAME=wawptn
DATABASE_URL=postgresql://wawptn:wawptn_secret@localhost:5432/wawptn

# ============================================
# AUTHENTICATION (REQUIRED IN PRODUCTION)
# ============================================
# Generate secure secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-change-in-production-min-32-chars
API_URL=http://localhost:3000

# ============================================
# STEAM INTEGRATION (REQUIRED)
# ============================================
# Get your Steam Web API key from https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-web-api-key

# ============================================
# FRONTEND DEVELOPMENT
# ============================================
VITE_API_URL=http://localhost:3000

# ============================================
# BACKEND CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
