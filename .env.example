# ============================================
# WAWPTN — Environment Variables
# ============================================

# ── Database ─────────────────────────────────
DB_USER=wawptn
DB_PASSWORD=wawptn_secret
DB_NAME=wawptn
DATABASE_URL=postgresql://wawptn:wawptn_secret@localhost:5432/wawptn

# ── Backend ──────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
API_URL=http://localhost:3000

# ── Authentication (required) ────────────────
# App-wide secret used for cookie signing, token encryption and HMAC
# Generate: openssl rand -base64 32
APP_SECRET=your-secret-key-change-in-production-min-32-chars

# ── Steam (required) ────────────────────────
# https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-web-api-key

# ── Epic Games (optional) ───────────────────
# EPIC_CLIENT_ID=
# EPIC_CLIENT_SECRET=
# EPIC_REDIRECT_URI=

# ── GOG Galaxy (optional) ───────────────────
# GOG_CLIENT_ID=
# GOG_CLIENT_SECRET=
# GOG_REDIRECT_URI=

# ── Discord Bot (optional) ──────────────────
# Shared secret between backend and bot: openssl rand -hex 32
# DISCORD_BOT_API_SECRET=
# Bot credentials (for packages/discord)
# DISCORD_BOT_TOKEN=
# DISCORD_APPLICATION_ID=
# BACKEND_URL=http://localhost:3000

# ── LLM (optional) ───────────────────────────
# Enables Discord bot conversational mode (OpenAI-compatible API)
# LLM_API_KEY=
# LLM_BASE_URL=https://models.inference.ai.azure.com
# LLM_MODEL=gpt-4o

# ── Stripe (optional — enables premium subscriptions) ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
